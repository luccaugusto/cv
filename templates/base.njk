<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <script src="https://kit.fontawesome.com/25199d3d0f.js" crossorigin="anonymous"></script>
    <style>
        body {
            background: rgb(40, 40, 40);
            font-family: sans-serif;
        }
        /* Link styling with subtle visual hints to indicate clickability */
        a {
            text-decoration: none;
            color: #2a2a2a;
            border-bottom: 1px dotted #6a6a6a;
            transition: border-bottom-color 0.2s ease, color 0.2s ease;
        }
        /* Hover effect to make links more interactive */
        a:hover {
            color: #1a1a1a;
            border-bottom-color: #4a4a4a;
        }
        /* A4 page container with exact height for proper pagination */
        .page-container {
            width: 210mm;
            height: 297mm;
            padding: 5mm 10mm;
            margin: 10mm auto;
            border: 1px #D3D3D3 solid;
            background: white;
            box-shadow: 0 0 5px rgba(0, 0, 0, 0.1);
            box-sizing: border-box;
            overflow: hidden;
            position: relative;
            page-break-after: always;
            page-break-inside: avoid;
        }
        /* Print media query for proper page breaks when printing */
        @media print {
            body {
                background: white;
            }
            .page-container {
                margin: 0;
                border: none;
                box-shadow: none;
                page-break-after: always;
            }
            .page-container:last-child {
                page-break-after: auto;
            }
            /* Ensure proficiency circles are visible and properly sized when printing */
            .proficiency-circles .circle {
                display: inline-block !important;
                width: 13px !important;
                height: 13px !important;
                min-width: 13px !important;
                min-height: 13px !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
                color-adjust: exact !important;
            }
            /* Ensure filled circles maintain their color when printing */
            .proficiency-circles[data-level="1"] .circle:nth-child(-n+1),
            .proficiency-circles[data-level="2"] .circle:nth-child(-n+2),
            .proficiency-circles[data-level="3"] .circle:nth-child(-n+3),
            .proficiency-circles[data-level="4"] .circle:nth-child(-n+4),
            .proficiency-circles[data-level="5"] .circle:nth-child(-n+5) {
                background-color: #4a4a4a !important;
                border-color: #4a4a4a !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
                color-adjust: exact !important;
            }
        }
        .header {
            text-align: left;
            margin-bottom: 20px;
        }
        .contact-info {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 5px 15px;
            font-size: 12px;
        }
        .item {
            display: flex;
            align-items: center;
            font-weight: 600;
        }
        .item i {
            margin-right: 5px;
        }
        .icon {
            color: #3b454a;
        }
        .cv-body {
            display: flex;
            width: 100%;
        }
        .content {
            flex: 5.5;
            padding-right: 25pt;
        }
        .sidebar {
            flex: 3.5;
        }
        .section-header {
            font-size: 28px;
            font-weight: 600;
            color: #5b5b5b;
            border-bottom: 3px solid #5b5b5b;
            padding-bottom: 4px;
            margin-bottom: 12px;
            line-height: 1;
        }
        .description {
            text-align: justify;
            font-size: 15px;
        }
        .subtitle {
            font-weight: 550;
            color: #4a4a4a;
            font-size: 14px;
        }
        .pill-list {
            font-weight: 500;
            color: #4a4a4a;
            list-style: none;
            padding: 0;
            margin: 8px 0;
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }
        .pill-list li {
            border-radius: 5px;
            padding: 3px 6px;
            font-size: 12px;
            border: 1px solid #b8b8b8;
        }
        .skill-list {
            margin-top: 8px;
        }
        .skill-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 14px;
        }
        .skill-name {
            color: #4a4a4a;
            font-weight: 600;
        }
        .proficiency-circles {
            display: flex;
            gap: 4px;
        }
        /* Circle styling with explicit display and print-friendly properties */
        .proficiency-circles .circle {
            width: 13px;
            height: 13px;
            min-width: 13px;
            min-height: 13px;
            border-radius: 50%;
            background-color: #d0d0d0;
            display: inline-block;
            /* Ensure colors print correctly */
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            /* Add border to ensure visibility even if background doesn't print */
            border: 1px solid #d0d0d0;
            box-sizing: border-box;
        }
        /* Filled circle style - applied based on data-level attribute */
        /* Ensure filled circles print correctly with explicit color adjustment */
        .proficiency-circles[data-level="1"] .circle:nth-child(-n+1),
        .proficiency-circles[data-level="2"] .circle:nth-child(-n+2),
        .proficiency-circles[data-level="3"] .circle:nth-child(-n+3),
        .proficiency-circles[data-level="4"] .circle:nth-child(-n+4),
        .proficiency-circles[data-level="5"] .circle:nth-child(-n+5) {
            background-color: #4a4a4a;
            border-color: #4a4a4a;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        .position {
            font-size: 18px;
            color: #404040;
            font-weight: 600;
        }
        .location {
            font-size: 16px;
            color: #5a5a5a;
        }
        .date {
            color: #6a6a6a;
            font-size: 16px;
        }
        .split-list {
            columns: 2;
            column-gap: 1rem;
            list-style: disc;
            padding-left: 1.2rem;
            margin: 0;
            font-size: 18px;
        }
        .experience-block {
            margin-bottom: 16px;
            display: flex;
            flex-direction: column;
            border-bottom: 1px dashed #d0d0d0;
        }
        .time-location {
            display: flex;
            gap: 15px;
            margin-top: 4px;
            font-size: 14px;
            justify-content: space-between;
        }
    </style>
    <title>{% block title %}{% endblock %}</title>
</head>
<body>
    {% block body %}{% endblock %}
</body>
</html>
