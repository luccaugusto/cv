{% extends "base.njk" %}
{% from "macros.njk" import contact_item, skill_row, experience_block, pill_list, education_entry %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    <!-- PAGE 1 -->
    <div class="page-container">
        <div class="header">
            <h1 style="margin-bottom: 12px; font-weight: 600">{{ name }}</h1>
            <div class="contact-info">
                {% for key in contact_items.swe %}
                {{ contact_item(contacts[key]) }}
                {% endfor %}
            </div>
        </div>
        <div class="cv-body">
            <div class="content">
                <h1 class="section-header">{{ labels.career_summary }}</h1>
                <p class="description">
                    {{ summary.swe | safe }}
                </p>
                <h1 class="section-header">{{ labels.experience }}</h1>
                {% for key in experience_order.swe.page1 %}
                    {{ experience_block(experiences[key], "swe") }}
                {% endfor %}
            </div>
            <div class="sidebar">
                <h1 class="section-header">{{ labels.languages }}</h1>
                <div>
                    <span class="subtitle">{{ labels.machine_languages }}</span>
                    {{ pill_list(machine_languages) }}
                </div>
                <div>
                    <span class="subtitle">{{ labels.human_languages }}</span>
                    <div class="skill-list">
                        {% for lang in human_languages %}
                        {{ skill_row(lang[0], lang[1]) }}
                        {% endfor %}
                    </div>
                </div>
                <h1 class="section-header">{{ labels.tech_skills }}</h1>
                <div class="skill-list">
                    {% for skill in tech_skills %}
                    {{ skill_row(skill[0], skill[1]) }}
                    {% endfor %}
                </div>
                <h1 class="section-header">{{ labels.soft_skills }}</h1>
                {{ pill_list(soft_skills.swe) }}
                <h1 class="section-header">{{ labels.education }}</h1>
                {% for edu in education %}
                {{ education_entry(edu, loop.last) }}
                {% endfor %}
            </div>
        </div>
    </div>

    <!-- PAGE 2 -->
    <div class="page-container">
        <div class="cv-body">
            <div class="content">
                <h1 class="section-header">{{ labels.experience }}</h1>
                {% for key in experience_order.swe.page2 %}
                    {{ experience_block(experiences[key], "swe") }}
                {% endfor %}
            </div>
        </div>
    </div>
{% endblock %}
